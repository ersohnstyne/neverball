<group name="worldspawn" color="0 0 0">
Used for most static level geometry.

For portability, all filenames should use the "/" (forward slash) character as the directory separator.

<string key="message" name="Introduction">Text that appears as a level begins.  A "\" (backslash) starts a new line.</string>
<background key="back" name="Background environment">Path to the background file. You need obtain from the template pack in order to use Switchball background levels: https://github.com/ersohnstyne/neverball-switchball-bundle-pack</background>
<gradient key="grad" name="Background gradient">Path to the background gradient image file. You need obtain from the template pack in order to use Switchball background gradients: https://github.com/ersohnstyne/neverball-switchball-bundle-pack</gradient>
<song key="song" name="Background music">Path to the background music file. You need obtain from the template pack in order to use Switchball soundtrack: https://github.com/ersohnstyne/neverball-switchball-bundle-pack</song>
<string key="shot" name="Level shot">Path to the level shot file.</string>
<integer key="goal" name="Required coins">Number of coins needed to unlock the goal. In Switchball, set the optional coins.</integer>
<integer key="time" name="Time limit">Level time limit in hundredths of a second. In Switchball, this value must be set as zero.</integer>
<string key="time_hs" name="Best Times">Default values for Best Times highscore, in order: Hard, Medium, and Easy (optional, defaults to time limit). In Switchball, three fields are required.</string>
<string key="goal_hs" name="Fast Unlock">Default values for Fast Unlock highscore, in order: Hard, Medium, and Easy (optional, defaults to time limit). In Switchball, three fields are required.</string>
<string key="coin_hs" name="Most Coins">Default values for Most Coins highscore, in order: Hard, Medium, and Easy (optional, defaults to required coins). In Switchball, three fields are required.</string>
<string key="version" name="Version">Version of the level.  The format should be "X.Y", where X is incremented every time the level is changed in a way that breaks existing replays, and Y is incremented for all other changes.</string>
<string key="author" name="Author">Name of the author. For all campaign maps, this field is required.</string>
<boolean key="bonus" name="Bonus level">Marks this level as a bonus level.</boolean>
<real key="idle" name="Idling time-out (Neverputt)">Neverputt: time to wait after the ball has stopped before starting the next shot.  Useful to ensure that moving objects won't hit the ball while the player is making the shot.</real>
<integer key="par" name="Par (Neverputt)">Neverputt: the number of strokes required to complete the hole.</integer>
</group>
</classes>
